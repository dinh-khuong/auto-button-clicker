{
  "manifest_version": 3,
  "name": "Auto Clicker",
  "description": "Auto click html elements",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["debugger", "alarms", "storage", "runtime", "tabs"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto Clicker Settings"
  }
}
