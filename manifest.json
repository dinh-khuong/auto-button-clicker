{
  "manifest_version": 3,
  "name": "Youtube skip add",
  "description": "Skip add when pause",
  "version": "1.0.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["debugger", "alarms"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["contentScript.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ad Skipper Settings"
  }
}
